# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carbon_aware

# JWT
JWT_SECRET=your-jwt-secret-key-here

# Redis
REDIS_URL=redis://localhost:6379

# ElectricityMap API (https://www.electricitymap.org/)
ELECTRICITY_MAP_API_KEY=your-electricity-map-api-key

# WattTime API (https://www.watttime.org/)
WATT_TIME_USERNAME=your-watttime-username
WATT_TIME_PASSWORD=your-watttime-password

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Environment
NODE_ENV=development
PORT=3001

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
