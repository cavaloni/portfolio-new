# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=carbon_aware_llm

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Redis Configuration (for rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Logging
LOG_LEVEL=info

# API Keys (these should be set in production)
WATT_TIME_EMAIL=
WATT_TIME_API_KEY=
ELECTRICITY_MAP_API_KEY=

# Novita.ai Configuration
NOVITA_API_KEY=your_novita_api_key_here
NOVITA_DEFAULT_GPU_TYPE=NVIDIA RTX 4090
NOVITA_AUTO_SCALING=true
NOVITA_MAX_REPLICAS_PER_MODEL=5
NOVITA_MIN_REPLICAS_PER_MODEL=0
NOVITA_DEFAULT_DEPLOYMENT_TYPE=model_api

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CARBON_ANALYTICS=true
ENABLE_NOVITA_INTEGRATION=true

# Temporary routing mock overlay
# When true, the router will report joystick-accurate model/region
# from a mock dataset while dispatching all traffic to a single
# always-warm deployment.
ROUTING_MOCK_ENABLED=false

# When ROUTING_MOCK_ENABLED=true, the chat endpoint will call Runpod
# Provide your Runpod API key to authorize requests
RUNPOD_API_KEY=
