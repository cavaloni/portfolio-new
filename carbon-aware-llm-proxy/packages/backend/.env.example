# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=carbon_aware_llm

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Redis Configuration (for rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Logging
LOG_LEVEL=info

# API Keys (these should be set in production)
WATT_TIME_EMAIL=
WATT_TIME_API_KEY=
ELECTRICITY_MAP_API_KEY=

# RunPod Configuration
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_DEFAULT_GPU_TYPE=NVIDIA GeForce RTX 4090
RUNPOD_AUTO_SCALING=true
RUNPOD_MAX_PODS_PER_MODEL=3
RUNPOD_MIN_PODS_PER_MODEL=1

# Feature Flags
ENABLE_RATE_LIMITING=true
ENABLE_CARBON_ANALYTICS=true
ENABLE_RUNPOD_INTEGRATION=true
